ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=your_service_role_key

ENTITY_BATCH_LIMIT=3
ENTITY_CRON=*/5 * * * *
CHUNK_DELAY_MS=500
LOG_LEVEL=info
PORT=3002

# מודל Claude
CLAUDE_MODEL=claude-haiku-4-5-20251001

# AUTO_RUN=false = ידני בלבד (ברירת מחדל — בטוח)
# AUTO_RUN=true  = מריץ אוטומטית כל X דקות
ENTITY_AUTO_RUN=false
